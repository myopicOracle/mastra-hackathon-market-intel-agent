{
  "name": "market-intel-agent",
  "version": "1.0.0",
  "description": "A Mastra template that fetches real-time market data from Polygon.io and generates an AI-powered Markdown market brief using OpenAI.",
  "main": "server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "start": "node dist/server.js",
    "build": "tsc"
  },
  "keywords": [
    "mastra",
    "ai",
    "template",
    "market-data",
    "polygon",
    "openai",
    "agent",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mastra/core": "^0.13.1",
    "@ai-sdk/openai": "^2.0.9",
    "ai": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
